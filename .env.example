# Production/docker deployment:
# 1. copy this file to `.env`
# 2. fill in the Telegram/Stripe/public URL values
# 3. deploy with `docker compose -f docker-compose.prod.yml up -d --build`
#
# Local development can still keep separate backend/frontend env files if needed.

# Docker Compose database defaults
POSTGRES_DB=miniapp_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
TELEGRAM_BOT_TOKEN=
WEBAPP_URL=https://example.com
ADMIN_IDS=123456789
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/miniapp_db
AUTO_MIGRATE_DB=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
VITE_API_URL=https://example.com
VITE_PRIVACY_POLICY_URL=
